# History control
shopt -s histappend
HISTCONTROL=ignoreboth
HISTSIZE=32768
HISTFILESIZE="${HISTSIZE}"

# Share history across panes in real time: append each command to the history
# file immediately and import commands written by other shells, so a freshly
# opened pane/tab has up-to-date history (default bash only writes it on exit).
PROMPT_COMMAND="history -a; history -n${PROMPT_COMMAND:+; $PROMPT_COMMAND}"

# Autocompletion
source /usr/share/bash-completion/bash_completion

# Set complete path
export PATH="./bin:$HOME/.local/bin:$HOME/.local/share/omakub/bin:$PATH"
export PATH="$HOME/Documents/work/developer-tools/anti-git-flow-scripts/:$PATH"
set +h

export OMAKUB_PATH="$HOME/.local/share/omakub"
