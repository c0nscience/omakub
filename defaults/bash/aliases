# OpenVPN
alias vpn='openvpn3'
alias vl='gum spin --show-output --title "Listing VPN sessions..." -- openvpn3 sessions-list'
alias vd='gum spin --show-output --title "Disconnecting VPN session (dilax)..." -- openvpn3 session-manage -D -c dilax'

vpn-config() {
    gum spin --title "Fetching VPN config from 1Password..." -- \
      op document get vpn-config --vault DILAX --out-file dilax.ovpn
    gum spin --show-output --title "Importing VPN config..." -- \
      openvpn3 config-import --config dilax.ovpn --name dilax -p --tag dilax
    rm dilax.ovpn
  }

vc() {
    local user pw otp
    user=$(gum spin --show-output --title "Fetching username from 1Password..." -- \
      op item get 'AD Account' --fields username --vault DILAX)
    pw=$(gum spin --show-output --title "Fetching password from 1Password..." -- \
      op item get 'AD Account' --fields password --vault DILAX --reveal)
    otp=$(gum spin --show-output --title "Generating OTP..." -- \
      op item get VPN --vault DILAX --otp)
    printf "$user\n$pw$otp\n" | gum spin --show-output --title "Starting VPN session..." -- \
      openvpn3 session-start --config dilax
  }

