alias cat='bat'

# File system
alias ls='eza -lh --group-directories-first --icons=auto'
alias l='ls'
alias ll='ls -al'
alias la='ls -a'
alias lt='eza --tree --level=2 --long --icons --git'
alias lta='lt -a'
alias ff="fzf -m --preview 'bat --style=numbers --color=always {}'"
alias cd='z'

# Directories
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

