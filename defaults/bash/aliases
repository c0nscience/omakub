# Aliases are an interactive-shell convenience, and bash only expands them when
# `expand_aliases` is set — which it is not in a non-interactive shell. Anything
# that snapshots this shell and force-enables `shopt -s expand_aliases` (Claude
# Code does exactly this) would otherwise inherit the whole set, and then `grep`
# is ripgrep, `ls` is eza and `cat` is bat — with different flags and output than
# the coreutils tools a generated script expects. Keep them interactive-only.
[[ $- == *i* ]] || return 0

alias cat='bat'

# File system
alias ls='eza -lh --group-directories-first --icons=auto'
alias l='ls'
alias ll='ls -al'
alias la='ls -a'
alias lt='eza --tree --level=2 --long --icons --git'
alias lta='lt -a'
alias ff="fzf -m --preview 'bat --style=numbers --color=always {}'"

# Directories
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Mise
alias ms8='mise shell java@zulu-8'
alias ms17='mise shell java@zulu-17'
alias ms21='mise shell java@zulu-21'
alias ms24='mise shell java@zulu-24'
alias mu8='mise use java@zulu-8'
alias mu17='mise use java@zulu-17'
alias mu21='mise use java@zulu-21'
alias mu24='mise use java@zulu-24'

# Tools
alias g='git'
alias d='docker'
alias grep='rg'
alias lzg='lazygit'
alias lzd='lazydocker'
alias http='xh'
alias k='kubectl'
complete -o default -F __start_kubectl k

# OpenVPN
alias vpn='openvpn3'
alias vl='gum spin --show-output --title "Listing VPN sessions..." -- openvpn3 sessions-list'
alias vd='gum spin --show-output --title "Disconnecting VPN session (dilax)..." -- openvpn3 session-manage -D -c dilax'

