# These initializers (mise/zoxide/fzf/atuin) hook readline and PROMPT_COMMAND and
# only do anything useful in an interactive shell. Bail out in non-interactive
# shells: at graphical login GDM's /etc/gdm3/Xsession sources ~/.profile ->
# ~/.bashrc -> this file in a NON-interactive bash, where `atuin init`'s readline
# `bind` prints "bind: warning: line editing not enabled" to stderr — and GDM
# turns any stderr from ~/.profile into a spurious "Error found when loading
# ~/.profile" popup (it checks `[ -s "$ERR" ]`, not the exit code).
[[ $- == *i* ]] || return 0

if command -v mise &> /dev/null; then
  eval "$(mise activate bash)"
fi

if command -v zoxide &> /dev/null; then
  # atuin/bash-preexec (below) hook PROMPT_COMMAND after zoxide, which trips
  # zoxide's doctor into a false "possible configuration issue" warning on every
  # shell. The ordering is intentional and zoxide still works, so skip the check.
  export _ZO_DOCTOR=0
  eval "$(zoxide init bash)"
fi

if command -v fzf &> /dev/null; then
  eval "$(fzf --bash)"
fi

if command -v fzf &> /dev/null; then
  if [[ -f /usr/share/bash-completion/completions/fzf ]]; then
    source /usr/share/bash-completion/completions/fzf
  fi
  if [[ -f /usr/share/doc/fzf/examples/key-bindings.bash ]]; then
    source /usr/share/doc/fzf/examples/key-bindings.bash
  fi
fi

if command -v atuin &> /dev/null; then
  if [ -f "$HOME/.config/atuin/bash-preexec.sh" ]; then
    source "$HOME/.config/atuin/bash-preexec.sh"
  fi
  eval "$(atuin init bash --disable-up-arrow)"
  # bash-preexec's install (first prompt) strips ignorespace from HISTCONTROL
  # because it reads commands back via `history 1`. Re-assert it every prompt
  # so leading-space commands stay out of the pane-shared history; in their
  # place atuin records the preceding command once more.
  __omakub_restore_histcontrol() { HISTCONTROL=ignoreboth; }
  precmd_functions+=(__omakub_restore_histcontrol)
fi
